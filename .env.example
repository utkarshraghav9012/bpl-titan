# BPL TITAN — Environment Variables
# Is file ko .env naam se copy karo aur apni values daalo
# KABHI BHAI .env file ko GitHub pe push mat karo!

# ======================
# ANTHROPIC CLAUDE AI
# ======================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=200

# ======================
# SERVER CONFIG
# ======================
# Python Flask port
PORT=5000

# Spring Boot port (application.properties mein bhi set karo)
# SERVER_PORT=8080

# Debug mode (production mein false rakho)
FLASK_DEBUG=false
